# --- Secrets ---
.env
.env.local
# secrets/ 디렉토리 전체 제외 — .lic / .key / .pem / .backup / WLS / 새 형식 등
# 어떤 시크릿 파일도 실수로 git 에 올라가지 않게. .gitkeep 만 추적 (디렉토리 유지).
secrets/*
!secrets/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.venv-host/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / Vite ---
node_modules/
dist/
.vite/
*.local

# --- Database ---
backend/data/*.db
backend/data/*.db-journal

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Claude Code 로컬 메모리/설정 ---
.claude/

# --- Optimizer Code 원본 ---
worker-origin/
