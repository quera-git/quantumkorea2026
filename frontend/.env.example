# 비워두면 vite dev proxy 가 /api → http://localhost:8000 로 라우팅한다.
# 절대 URL 을 직접 호출하고 싶다면 다음과 같이 지정:
# VITE_BACKEND_URL=http://localhost:8000

# 결과 폴링 간격(ms). 기본 5000.
# VITE_POLL_INTERVAL_MS=5000

# 부스 데모 모드 — backend 없는 frontend-only 배포 (Vercel) 에서 사용.
# 1 로 설정하면:
#   - 라이브 BPTC 패널 숨김 (backend /crawler 호출 X)
#   - BPT 직접 워크플로 섹션 + NAV 항목 숨김 (BptPanel/SolverPanel/등)
#   - 시나리오 + 편집 워크플로 + 4-way 비교만 노출 — frontend 정적 자산만으로 동작
# 로컬 개발 / Docker 풀스택에선 비워두거나 0 으로.
# VITE_DEMO_MODE=1
